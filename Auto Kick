local openThread
local function StartOpenLoop()
    if openThread then return end
    openThread = task.spawn(function()
        while S.AutoOpen do
            pcall(function()
                local conv = GetConveyor()
                if not conv then task.wait(1); return end
                local prompt = FindMatchingPrompt(conv)
                local rerolls = 0
                while not prompt and S.AutoOpen and rerolls < S.MaxRerolls do
                    RerollConveyor(); task.wait(0.35)
                    conv = GetConveyor()
                    if conv then prompt = FindMatchingPrompt(conv) end
                    rerolls = rerolls + 1
                end
                if not prompt then return end
                if S.AutoBuy then fireproximityprompt(prompt); task.wait(0.4) end
                OpenCase()
            end)
        end
        openThread = nil
    end)
end
