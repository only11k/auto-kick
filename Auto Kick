local function findEv(name)
    if not Events then return nil end
    local exact = Events:FindFirstChild(name)
    if exact then return exact end
    local lower = name:lower()
    for _, v in ipairs(Events:GetChildren()) do
        if v.Name:lower() == lower then return v end
    end
    return nil
end

local function scanRewardEvents()
    local found = {}
    if not Events then return found end
    local keywords = {
        "claim", "reward", "bonus", "offline", "earnings", "casepot",
        "timed", "individual", "hatched", "leaver", "free", "premium", "knife",
        "activity", "playtime", "minute",
    }
    for _, v in ipairs(Events:GetChildren()) do
        local lower = v.Name:lower()
        for _, kw in ipairs(keywords) do
            if lower:find(kw) then found[v.Name] = v; break end
        end
    end
    return found
end

