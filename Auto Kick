function Tab:Dropdown(text, options, current, multi, cb, getOptions)
    local selected = {}
    if type(current) == "table" then
        for _, v in ipairs(current) do selected[v] = true end
    elseif current then selected[current] = true end

    local f = mk("Frame", {Size = UDim2.new(1,0,0,34), BackgroundColor3 = Theme.Panel2,
        BorderSizePixel = 0, ClipsDescendants = true}, {corner(8)})
    local head = mk("TextButton", {Text = "", AutoButtonColor = false,
        Size = UDim2.new(1,0,0,34), BackgroundTransparency = 1, BorderSizePixel = 0})
    head.Parent = f
    mk("TextLabel", {Text = text, Font = Enum.Font.GothamMedium, TextSize = 13,
        TextColor3 = Theme.Text, BackgroundTransparency = 1, Size = UDim2.new(0.5,0,1,0),
        Position = UDim2.fromOffset(10,0), TextXAlignment = Enum.TextXAlignment.Left}).Parent = head
    local valLbl = mk("TextLabel", {Text = "", Font = Enum.Font.Gotham, TextSize = 12,
        TextColor3 = Theme.Accent, BackgroundTransparency = 1, Size = UDim2.new(0.5,-30,1,0),
        Position = UDim2.new(0.5,0,0,0), TextXAlignment = Enum.TextXAlignment.Right})
    valLbl.Parent = head
    local arrow = mk("TextLabel", {Text = "v", Font = Enum.Font.GothamBold, TextSize = 12,
        TextColor3 = Theme.Sub, BackgroundTransparency = 1, Size = UDim2.fromOffset(20,34),
        Position = UDim2.new(1,-26,0,0)})
    arrow.Parent = head

    local list = mk("Frame", {Size = UDim2.new(1,0,0,0), Position = UDim2.fromOffset(0,34),
        BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y},
        {pad(6), mk("UIListLayout", {Padding = UDim.new(0,4)})})
    list.Parent = f

    local function refreshLabel()
        local sel = {}
        for k, v in pairs(selected) do if v then sel[#sel+1] = k end end
        valLbl.Text = #sel > 0 and table.concat(sel, ", ") or "(none)"
        if #valLbl.Text > 28 then valLbl.Text = #sel .. " selected" end
    end

    local function buildOptions()
        for _, c in ipairs(list:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local opts = getOptions and getOptions() or options
        for _, opt in ipairs(opts) do
            local on = selected[opt]
            local ob = mk("TextButton", {Text = "  " .. opt, Font = Enum.Font.Gotham,
                TextSize = 12, TextColor3 = on and Theme.Text or Theme.Sub,
                BackgroundColor3 = on and Theme.AccentDim or Theme.Bg, BorderSizePixel = 0,
                Size = UDim2.new(1,0,0,26), AutoButtonColor = true,
                TextXAlignment = Enum.TextXAlignment.Left}, {corner(6)})
            ob.Parent = list
            ob.MouseButton1Click:Connect(function()
                if multi then
                    selected[opt] = not selected[opt]
                else
                    for k in pairs(selected) do selected[k] = nil end
                    selected[opt] = true
                end
                local sel = {}
                for k, v in pairs(selected) do if v then sel[#sel+1] = k end end
                refreshLabel(); buildOptions()
                pcall(cb, sel)
                if not multi then
                    f:TweenSize(UDim2.new(1,0,0,34), Enum.EasingDirection.Out,
                        Enum.EasingStyle.Quad, 0.15, true)
                    arrow.Text = "v"
                end
            end)
        end
    end

    local open = false
    head.MouseButton1Click:Connect(function()
        open = not open
        if open then buildOptions() end
        arrow.Text = open and "^" or "v"
        local h = 34
        if open then
            local opts = getOptions and getOptions() or options
            h = 34 + 6 + (#opts * 30) + 6
        end
        f:TweenSize(UDim2.new(1,0,0,h), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.18, true)
    end)

    refreshLabel()
    f.Parent = self.page
    return {Refresh = function() if open then buildOptions() end end}
end

