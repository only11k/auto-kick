local function gatherGems()
    local list = {}
    for _, folder in ipairs({
        game.Workspace:FindFirstChild("Strange Gems"),
        game.Workspace:FindFirstChild("ActiveRunStrangeGems"),
    }) do
        if folder then
            for _, d in ipairs(folder:GetDescendants()) do
                if isGem(d) then list[#list+1] = d end
            end
        end
    end
    return list
end

local ToggleMorph = Events and Events:FindFirstChild("ToggleMorphVisibility")

local function CollectAllGems()
    local char = LocalPlayer.Character; if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local gems = gatherGems()
    if #gems == 0 then return end
    local origin = hrp.CFrame
    pcall(function() if E.RequestGemRun then E.RequestGemRun:FireServer("Begin", hrp.Position) end end)
    pcall(function() if ToggleMorph then ToggleMorph:FireServer(true) end end)
    task.wait(0.15)
    for _, gem in ipairs(gems) do
        if gem and gem.Parent then
            pcall(function() hrp.CFrame = gem.CFrame end)
            task.wait(0.05)
            S.TotalGems = S.TotalGems + 1
        end
    end
    pcall(function() if ToggleMorph then ToggleMorph:FireServer(false) end end)
    pcall(function() if E.RequestGemRun then E.RequestGemRun:FireServer("End") end end)
    pcall(function() hrp.CFrame = origin end)
end

