local RARITY_ORDER = {
    "Common","Rare","Mythic","Legendary","Transcendent","Supreme","Sacred",
    "Divine","Exotic","Demon","World","Zero","Soul","Forgotten","Unforgotten",
    "Digital","Horizon","Sundered","Igneous"
}
local function rarityRank(name)
    name = tostring(name):lower()
    for i, r in ipairs(RARITY_ORDER) do
        if r:lower() == name then return i end
    end
    return 999
end

local sellThread
local function DoSell()
    local sellReq = Events and Events:FindFirstChild("RequestSell")
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    if not (sellReq and hum and bp) then return end
    local maxRank = rarityRank(S.SellMaxRarity)
    for _, tool in ipairs(bp:GetChildren()) do
        if not S.AutoSell then break end
        if tool:IsA("Tool") then
            local rar = tool:GetAttribute("Rarity")
            local mut = tool:GetAttribute("Mutation")
            local ln  = tool.Name:lower()
            local isCase = ln:find("case") or ln:find("block")
            local hasMut = mut and mut ~= "" and tostring(mut):lower() ~= "none"
            if rar and not isCase and rarityRank(rar) <= maxRank
               and not (S.SellKeepMutated and hasMut) then
                pcall(function() hum:EquipTool(tool) end)
                task.wait(0.1)
                pcall(function() sellReq:FireServer("Equipped") end)
                task.wait(0.1)
            end
        end
    end
end
local function StartSell()
    if sellThread then return end
    sellThread = task.spawn(function()
        while S.AutoSell do pcall(DoSell); task.wait(S.SellDelay) end
        sellThread = nil
    end)
end
local function StopSell() S.AutoSell = false; sellThread = nil end

local MutationList = {
    "Any","Wooden","Normal","Golden","Diamond","Crimson","Viridian",
    "Ethereal","Celestial","Prismatic","Eclipse","Astral","Primordial",
    "Galactic","Lunar","Timeless","Abyss"
}
local RarityList = {
    "Any","Common","Rare","Mythic","Legendary","Transcendent","Supreme",
    "Sacred","Divine","Exotic","Demon","World","Zero","Soul","Forgotten",
    "Unforgotten","Digital","Horizon","Sundered","Igneous"
}

local function tableContains(t, value)
    for _, v in ipairs(t) do if v == value then return true end end
    return false
end

local function CaseMatches(name)
    local parts = {}
    for p in name:gmatch("([^_]+)") do parts[#parts+1] = p end
    local mut = parts[2] or ""
    local rar = parts[3] or ""
    local mOk = tableContains(S.SelectedMutations, "Any") or tableContains(S.SelectedMutations, mut)
    local rOk = tableContains(S.SelectedRarities, "Any") or tableContains(S.SelectedRarities, rar)
    return mOk and rOk
end

local function GetPlot()
    local direct = game.Workspace:FindFirstChild("Plot_" .. LocalPlayer.Name)
    if direct then return direct end
    for _, v in ipairs(game.Workspace:GetChildren()) do
        if v.Name:find("Plot") then
            local o = v:GetAttribute("Owner") or v:GetAttribute("owner") or v:GetAttribute("PlayerName")
            if o == LocalPlayer.Name or o == LocalPlayer.UserId then return v end
        end
    end
    for _, v in ipairs(game.Workspace:GetChildren()) do
        if v.Name:find("Plot") then
            if v:FindFirstChild("CaseConveyor") then return v end
        end
    end
end

local function GetConveyor()
    local p = GetPlot()
    return p and p:FindFirstChild("CaseConveyor") or nil
end

local function RerollConveyor()
    local c = GetConveyor(); if not c then return false end
    local b = c:FindFirstChild("RerollButton"); if not b then return false end
    local cl = b:FindFirstChild("Clicker"); if not cl then return false end
    local cd = cl:FindFirstChild("RerollClickDetector"); if not cd then return false end
    pcall(function() fireclickdetector(cd) end)
    return true
end

local function FindMatchingPrompt(conveyor)
    for _, child in ipairs(conveyor:GetChildren()) do
        if child.Name:find("ForSale_") and CaseMatches(child.Name) then
            local proxy = child:FindFirstChild("PurchaseProxy")
            if proxy then
                local prompt = proxy:FindFirstChildWhichIsA("ProximityPrompt")
                if prompt then return prompt, child.Name end
            end
        end
    end
    return nil, nil
end

local function bestMatch(name, list)
    local best
    for _, item in ipairs(list) do
        if item ~= "Any" and name:find(item:lower(), 1, true) then
            if not best or #item > #best then best = item end
        end
    end
    return best
end
local function detectEquippedCase()
    local char = LocalPlayer.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    if not tool then return nil, nil, nil end
    local n = tool.Name:lower()
    return bestMatch(n, RarityList), bestMatch(n, MutationList), tool
end

local function findCaseTool(container)
    if not container then return nil end
    for _, t in ipairs(container:GetChildren()) do
        if t:IsA("Tool") then
            local ln = t.Name:lower()
            if ln:find("case") or ln:find("block") or bestMatch(ln, RarityList) then
                return t
            end
        end
    end
    return nil
end

local function equipCaseIfNeeded()
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if char:FindFirstChildOfClass("Tool") then return end
    local tool = findCaseTool(LocalPlayer:FindFirstChild("Backpack"))
    if tool then pcall(function() hum:EquipTool(tool) end); task.wait(0.1) end
end

local function DoKick()
    local consume = Events and Events:FindFirstChild("ConsumeEquippedLuckyBlock")
    local claim   = Events and Events:FindFirstChild("ClaimHatchedItem")
    if not consume then return false, "ConsumeEquippedLuckyBlock not found" end

    equipCaseIfNeeded()

    local rarity = detectEquippedCase() or (S.KickBlockType ~= "" and S.KickBlockType) or "Forgotten"
    if rarity then S.KickBlockType = rarity end

    local ok, _success, reward = pcall(function() return consume:InvokeServer(rarity) end)

    S.TotalKicks  = S.TotalKicks + 1
    S.TotalOpened = S.TotalOpened + 1

    if ok and type(reward) == "table" and claim then
        local item = reward.RewardItemName
        local rar  = reward.RewardRarity or rarity
        local mut  = reward.RewardMutation
        if item then
            if mut and mut ~= "" then
                pcall(function() claim:FireServer(item, rar, mut) end)
            else
                pcall(function() claim:FireServer(item, rar) end)
            end
            if reward.RewardIsNewKnife then
                local msg = tostring(item) .. " [" .. tostring(rar)
                    .. (mut and (" / " .. mut) or "") .. "]"
                if NotifyHook then NotifyHook("NEW knife!", msg, 4) end
                SendWebhook("New knife!", msg)
            end
            return true, "Kick: " .. tostring(item) .. " [" .. tostring(rar)
                         .. (mut and (" / " .. mut) or "") .. "]"
        end
    end
    return true, "Consume(" .. tostring(rarity) .. ") - no reward table"
end

