local function CollectCash()
    local plot = GetPlot(); if not plot then return end
    local char = LocalPlayer.Character; if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    for _, floor in ipairs(plot:GetChildren()) do
        if floor.Name:find("Floor") then
            local slots = floor:FindFirstChild("Slots")
            if slots then
                for _, slot in ipairs(slots:GetChildren()) do
                    local ct = slot:FindFirstChild("CollectTouch")
                    if ct then
                        pcall(function() firetouchinterest(hrp, ct, 0) end)
                        pcall(function() firetouchinterest(hrp, ct, 1) end)
                    end
                end
            end
        end
    end
    Fire(E.ClaimOfflineEarnings)
    S.TotalCash = S.TotalCash + 1
end

